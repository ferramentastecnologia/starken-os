# syntax=docker/dockerfile:1.4
# ============================================================
# ASSESSORIA AI Agents — Multi-stage Dockerfile
# Python 3.11-slim | Target image < 500 MB
#
# Stage 1 (builder): compiles all Python deps into /opt/venv
# Stage 2 (runtime): lean image, non-root user, no build tools
#
# Playwright browsers are intentionally NOT installed here.
# The geo-seo agent connects to the playwright-service sidecar
# via CDP/WebSocket (PLAYWRIGHT_WS_ENDPOINT env var).
# ============================================================

# ────────────────────────────────────────────────────────────
# Stage 1 — builder
# ────────────────────────────────────────────────────────────
FROM python:3.11-slim AS builder

# Build-time OS dependencies needed to compile Python extensions:
#   gcc        — C compiler for packages with C extensions
#   libxml2-dev / libxslt-dev — lxml build headers
#   libjpeg-dev / zlib1g-dev  — Pillow build headers
RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        libxml2-dev \
        libxslt-dev \
        libjpeg-dev \
        zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

# Create an isolated virtual environment so only /opt/venv is
# copied to the runtime stage (no global site-packages noise).
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy the merged requirements file before installing so that
# the BuildKit cache layer is invalidated only when it changes.
COPY requirements.agents.txt /tmp/requirements.agents.txt

# Install all Python dependencies.
# --mount=type=cache keeps the pip wheel cache between builds,
# which dramatically speeds up layer rebuilds.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --upgrade pip setuptools wheel \
    && pip install -r /tmp/requirements.agents.txt

# ────────────────────────────────────────────────────────────
# Stage 2 — runtime
# ────────────────────────────────────────────────────────────
FROM python:3.11-slim AS runtime

# Runtime-only OS libraries (shared objects, no -dev headers).
#   libxml2   — lxml runtime
#   libjpeg62-turbo / zlib1g — Pillow / image runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
        libxml2 \
        libjpeg62-turbo \
        zlib1g \
    && rm -rf /var/lib/apt/lists/*

# Pull only the pre-built virtual environment from the builder.
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# ── Non-root user ────────────────────────────────────────────
RUN groupadd --gid 1001 agentuser \
    && useradd --uid 1001 --gid agentuser --shell /bin/bash \
                --create-home agentuser

# ── Application layout ───────────────────────────────────────
WORKDIR /app

# Copy each agent into its canonical subdirectory.
# JSON array syntax is required for source paths that contain spaces.
COPY ["AGENTES CLAUDE CODE/ai-marketing-claude-main", "/app/agents/marketing/"]
COPY ["AGENTES 2/ai-sales-team-claude-main",          "/app/agents/sales/"]
COPY ["AGENTES 3/geo-seo-claude-main",                "/app/agents/geoseo/"]

# Copy the dispatcher module that routes --agent invocations.
COPY agents/dispatcher.py /app/agents/dispatcher.py

# Shared data directory (reports, cached results, memory).
RUN mkdir -p /app/data && chown -R agentuser:agentuser /app

USER agentuser

# ── Environment ──────────────────────────────────────────────
ENV PYTHONPATH=/app \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    # geo-seo agent connects here instead of launching browsers
    PLAYWRIGHT_WS_ENDPOINT=ws://playwright-service:9222

# ── Entry point ──────────────────────────────────────────────
# Override CMD to run a specific agent:
#   docker run assessoria-agents --agent marketing --task analyze
ENTRYPOINT ["python"]
CMD ["-m", "agents.dispatcher"]
