# ============================================================================
# Starken OS — Environment Variables Template
# ============================================================================
# Copiar este arquivo para .env e preencher com valores reais
# NUNCA commitar .env com valores reais!
# ============================================================================

# Node.js
NODE_ENV=production
PORT=3000

# ============================================================================
# SUPABASE — Banco de dados
# ============================================================================
# Obter em: https://app.supabase.com → Project Settings → API

SUPABASE_URL=https://cpwpxckmuecejtkcobre.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# META GRAPH API — Facebook/Instagram
# ============================================================================
# Obter em: https://developers.facebook.com/apps/

META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
META_API_VERSION=v25.0

# ============================================================================
# ASANA (OPCIONAL)
# ============================================================================

ASANA_PAT=your_asana_pat_here

# ============================================================================
# LOGGING & MONITORING (OPCIONAL)
# ============================================================================

LOG_LEVEL=info
SENTRY_DSN=

# ============================================================================
# VERCEL ENV (compatibilidade)
# ============================================================================

VERCEL=false
VERCEL_ENV=production
