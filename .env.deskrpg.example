# =============================================================================
# DeskRPG Integration Configuration - Phase 5
# =============================================================================
# Copy this file to .env.local or add these variables to your Vercel environment

# CRITICAL QUESTIONS (Phase 5 blocking items):

# 1. Where is DeskRPG running?
#    - Localhost: http://localhost:3000
#    - Docker: http://deskrpg:3000
#    - Remote URL: https://deskrpg.your-domain.com
DESKRPG_BASE_URL=http://localhost:3000

# 2. What authentication does DeskRPG require?
#    Options: 'bearer' (Bearer token), 'apikey' (X-API-Key header), 'none' (no auth)
DESKRPG_AUTH_TYPE=none

# 3. If authentication is required, provide the token/key
#    Leave empty if using 'none' auth type
DESKRPG_AUTH_TOKEN=

# 4. Webhook callback URL (how does DeskRPG send results back to Starken OS?)
#    - Local dev: http://localhost:7001/api/deskrpg-webhook
#    - Vercel: https://starken-os.vercel.app/api/deskrpg-webhook
DESKRPG_WEBHOOK_URL=http://localhost:7001/api/deskrpg-webhook

# =============================================================================
# DEPLOYMENT INSTRUCTIONS
# =============================================================================
#
# LOCAL DEVELOPMENT:
# 1. Copy this file: cp .env.deskrpg.example .env.local
# 2. Update values for your DeskRPG setup
# 3. Restart local server
#
# VERCEL DEPLOYMENT:
# 1. Go to Vercel Project Settings → Environment Variables
# 2. Add each variable above as a new environment variable
# 3. Redeploy the project
#
# DOCKER SETUP (if running DeskRPG in Docker):
# 1. Ensure DeskRPG is accessible via internal network
# 2. Use DESKRPG_BASE_URL=http://deskrpg:3000 (docker service name)
# 3. Update webhook URL to point to Starken OS external URL
#
# =============================================================================
